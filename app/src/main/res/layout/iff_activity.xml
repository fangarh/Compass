<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060a08"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:weightSum="4">

        <Button
            android:id="@id/iff_contact_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            android:background="@drawable/popup_button"
            android:text="CONTACT"
            android:textColor="#ffd16a"
            android:textSize="12sp" />

        <Button
            android:id="@id/iff_team_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            android:background="@drawable/popup_button"
            android:text="TEAM"
            android:textColor="#b8c49a"
            android:textSize="12sp" />

        <Button
            android:id="@id/iff_map_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            android:background="@drawable/popup_button"
            android:text="MAP"
            android:textColor="#b8c49a"
            android:textSize="12sp" />

        <Button
            android:id="@id/iff_log_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_weight="1"
            android:background="@drawable/popup_button"
            android:text="LOG"
            android:textColor="#b8c49a"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@id/iff_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#ffffff"
        android:textSize="22sp" />

    <TextView
        android:id="@id/iff_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#b8c49a"
        android:textSize="13sp" />

    <TextView
        android:id="@id/iff_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#182015"
        android:padding="8dp"
        android:textColor="#ffd16a"
        android:textSize="13sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@id/iff_body_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@id/iff_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:textColor="#d8dfca"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:weightSum="4">

        <Button
            android:id="@id/iff_approach"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            android:background="@drawable/popup_button"
            android:text="APPROACH"
            android:textColor="#ffffff"
            android:textSize="8sp" />

        <Button
            android:id="@id/iff_trust"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            android:background="@drawable/popup_button"
            android:text="TRUST"
            android:textColor="#ffd16a"
            android:textSize="8sp" />

        <Button
            android:id="@id/iff_record_check"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_weight="1"
            android:background="@drawable/popup_button"
            android:text="CHECK"
            android:textColor="#ffffff"
            android:textSize="8sp" />

        <Button
            android:id="@id/iff_radio_service"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_weight="1"
            android:background="@drawable/popup_button"
            android:text="RADIO ON"
            android:textColor="#ffffff"
            android:textSize="8sp" />
    </LinearLayout>
</LinearLayout>
